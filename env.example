# ─────────────────────────────────────────────────────────────────────────────
# Saving-Bot-v0.1 — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Whitelist ─────────────────────────────────────────────────────────────────
# Comma-separated list of numbers allowed to use the bot.
# Include BOTH the phone format AND the LID format for each person.
# Format: country code + number, no + or spaces (e.g. 923001234567)
# How to find LIDs: start bot, have person send a message, check logs for
# the line: "🔍 Resolved 161942429786177@lid → 161942429786177"
WHITELIST=923132411794794,16194243423429786177,92324234198958,133977478766855

# ── Notification recipients ───────────────────────────────────────────────────
# Comma-separated list of numbers that receive scheduled Excel backups.
# Use phone format only (no LIDs).
NOTIFY_NUMBERS=923678794794,923244850958

# ── Template path ─────────────────────────────────────────────────────────────
# Path to the blank Excel template used to create new year files.
# Relative to the bot folder.
TEMPLATE_PATH=./Template.xlsx

# ── Timezone ──────────────────────────────────────────────────────────────────
# Used by the scheduler for cron jobs.
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Asia/Karachi
