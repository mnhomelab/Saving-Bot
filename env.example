# ─────────────────────────────────────────────────────────────────────────────
# Saving-Bot-v0.1 — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Whitelist ─────────────────────────────────────────────────────────────────
# Comma-separated list of numbers allowed to use the bot.
# Include BOTH the phone format AND the LID format for each person.
# Format: country code + number, no + or spaces (e.g. 923001234567)
# How to find LIDs: start bot, have person send a message, check logs for
# the line: "🔍 Resolved 161942429786177@lid → 161942429786177"
WHITELIST=923132411794794,16194243423429786177,92324234198958,133977478766855

# ── Notification recipients ───────────────────────────────────────────────────
# Comma-separated list of numbers that receive scheduled Excel backups.
# Use phone format only (no LIDs).
NOTIFY_NUMBERS=923678794794,923244850958

# ── Template path ─────────────────────────────────────────────────────────────
# Path to the blank Excel template used to create new year files.
# Relative to the bot folder.
TEMPLATE_PATH=./Template.xlsx

# ── Timezone ──────────────────────────────────────────────────────────────────
# Used by the scheduler for cron jobs.
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Asia/Karachi

# ── Dashboard ─────────────────────────────────────────────────────────────────
# Public URL of the dashboard (used for link generation in WhatsApp messages).
DASHBOARD_PORT=3001
DASHBOARD_HOST=http://YOUR_SERVER_IP:3001

# ── OnlyOffice Document Server ────────────────────────────────────────────────
#
# HOW THE TWO URLs WORK:
#
#   ONLYOFFICE_DS_URL    → URL your BROWSER uses to reach OnlyOffice DS.
#                          This must be reachable from the user's device.
#                          Example: http://YOUR_SERVER_IP:8080
#
#   BOT_CALLBACK_HOST    → URL OnlyOffice DS uses to reach THIS bot (internally).
#                          OnlyOffice DS calls this to download the xlsx and to
#                          post save callbacks. Since both run in Docker on the
#                          same bot-net network, use the bot's container name.
#                          Example: http://saving-bot-v0.1:3001
#
#   ONLYOFFICE_SECRET    → Random secret that authenticates the file-serve and
#                          callback endpoints (no browser session available there).
#                          Generate with: openssl rand -hex 24
#
ONLYOFFICE_DS_URL=http://YOUR_SERVER_IP:8080
BOT_CALLBACK_HOST=http://saving-bot-v0.1:3001
ONLYOFFICE_SECRET=change-me-generate-with-openssl-rand-hex-24

# ── Email Alerts ──────────────────────────────────────────────────────────────
# Sends alerts when values are changed/deleted/replaced and on service events.
# Leave blank to disable email alerts entirely.
#
# Gmail setup:
#   1. Enable 2FA on your Google account
#   2. Go to: Google Account → Security → App Passwords
#   3. Generate an App Password for "Mail"
#   4. Use that 16-char password as SMTP_PASS
#
# Outlook / Office 365:
#   SMTP_HOST=smtp.office365.com  SMTP_PORT=587
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=xxxxxxxxxxxxxxxxxxxx
# Paste the 16-char app password exactly as Google shows it (spaces OK — they are stripped automatically)
SMTP_FROM=your@gmail.com
ALERT_EMAIL=alert-recipient@gmail.com
# Multiple recipients (comma-separated):
# ALERT_EMAIL=you@gmail.com,other@gmail.com
